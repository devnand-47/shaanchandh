# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Clerk Authentication (Frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk Authentication (Backend)
CLERK_SECRET_KEY=sk_test_...

